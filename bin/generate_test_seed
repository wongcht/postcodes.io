#!/usr/bin/env bash
#
# Generate test/seed/seed.sql.gz from a loaded postcodesiodb.
#
# Reads from a fully-populated DB under the `public` schema (typically the dev
# compose stack: POSTGRES_HOST=127.0.0.1 POSTGRES_PORT=5433
# POSTGRES_DATABASE=postcodesiodb).
#
# Output is a self-contained SQL stream:
#   CREATE EXTENSION postgis;
#   CREATE TABLE (pre-data)
#   COPY <filtered rows> for each table
#   CREATE INDEX + constraints (post-data)
#
# Indexes are emitted last so bulk loads are fast.

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
OUT="$ROOT/test/seed/seed.sql.gz"

HOST="${POSTGRES_HOST:-127.0.0.1}"
PORT="${POSTGRES_PORT:-5433}"
USER="${POSTGRES_USER:-postcodesio}"
PASSWORD="${POSTGRES_PASSWORD:-password}"
DB="${POSTGRES_DATABASE:-postcodesiodb}"

export PGPASSWORD="$PASSWORD"
PG_DUMP=(pg_dump -h "$HOST" -p "$PORT" -U "$USER" -d "$DB" --no-owner --no-privileges)
PSQL=(psql -h "$HOST" -p "$PORT" -U "$USER" -d "$DB" -At)

POSTCODES_FILTER="postcode LIKE 'AB1%' OR postcode IN ('SE1P 5ZZ','SE1 9ZZ','JE2 4WD','M11 1AA','M1 1AD','SE1 2DL')"
PLACES_FILTER="outcode IN ('KW16','KW17')"
SCOTTISH_FILTER="postcode LIKE 'AB1%'"
OUTCODES_FILTER="outcode LIKE 'AB1%' OR outcode IN ('SE1','SE1P','JE2','M11','M1','KW16','KW17')"

emit_copy() {
  local table="$1" filter="$2"
  echo "COPY public.$table FROM STDIN;"
  "${PSQL[@]}" -c "\copy (SELECT * FROM public.$table WHERE $filter) TO STDOUT"
  echo "\\."
  echo
}

{
  printf -- "-- Generated by bin/generate_test_seed on %s\n" "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  echo "-- Filters:"
  echo "--   postcodes: $POSTCODES_FILTER"
  echo "--   places: $PLACES_FILTER"
  echo "--   scottish_postcodes: $SCOTTISH_FILTER"
  echo "--   outcodes: $OUTCODES_FILTER"
  echo
  echo "CREATE EXTENSION IF NOT EXISTS postgis;"
  echo
  "${PG_DUMP[@]}" --schema-only --section=pre-data -n public \
    | sed 's/^CREATE SCHEMA public;$/CREATE SCHEMA IF NOT EXISTS public;/'
  echo
  emit_copy postcodes "$POSTCODES_FILTER"
  emit_copy places "$PLACES_FILTER"
  emit_copy scottish_postcodes "$SCOTTISH_FILTER"
  emit_copy outcodes "$OUTCODES_FILTER"
  "${PG_DUMP[@]}" --schema-only --section=post-data -n public
} | gzip -9 > "$OUT"

uncompressed_kb="$(gunzip -c "$OUT" | wc -c | awk '{printf "%.0f", $1/1024}')"
gz_kb="$(wc -c < "$OUT" | awk '{printf "%.0f", $1/1024}')"
printf "wrote %s (%s KB gzipped, %s KB uncompressed)\n" "$OUT" "$gz_kb" "$uncompressed_kb"
