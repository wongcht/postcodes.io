#!/usr/bin/env bash
#
# Generate test/seed/v13.sql.gz from a loaded postcodesiodb.
#
# Reads from a fully-populated DB under schema pcio (typically the dev compose
# stack: POSTGRES_HOST=127.0.0.1 POSTGRES_PORT=5433 POSTGRES_DATABASE=postcodesiodb).
#
# Output is a self-contained SQL stream:
#   CREATE EXTENSION postgis;
#   CREATE SCHEMA pcio + CREATE TABLE (pre-data)
#   COPY <filtered rows> for each table
#   CREATE INDEX + constraints (post-data)
#
# Indexes are emitted last so bulk loads are fast.

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
OUT="$ROOT/test/seed/v13.sql.gz"

HOST="${POSTGRES_HOST:-127.0.0.1}"
PORT="${POSTGRES_PORT:-5433}"
USER="${POSTGRES_USER:-postcodesio}"
PASSWORD="${POSTGRES_PASSWORD:-password}"
DB="${POSTGRES_DATABASE:-postcodesiodb}"

export PGPASSWORD="$PASSWORD"
PG_DUMP=(pg_dump -h "$HOST" -p "$PORT" -U "$USER" -d "$DB" --no-owner --no-privileges)
PSQL=(psql -h "$HOST" -p "$PORT" -U "$USER" -d "$DB" -At)

ONSPD_FILTER="postcode LIKE 'AB1%' OR postcode IN ('SE1P 5ZZ','SE1 9ZZ','JE2 4WD','M11 1AA','M1 1AD','SE1 2DL')"
OPENNAMES_FILTER="outcode IN ('KW16','KW17')"
SPD_FILTER="postcode LIKE 'AB1%'"

emit_copy() {
  local table="$1" filter="$2"
  echo "COPY pcio.$table FROM STDIN;"
  "${PSQL[@]}" -c "\copy (SELECT * FROM pcio.$table WHERE $filter) TO STDOUT"
  echo "\\."
  echo
}

{
  printf -- "-- Generated by bin/generate_test_seed on %s\n" "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  echo "-- Filters:"
  echo "--   onspd: $ONSPD_FILTER"
  echo "--   opennames: $OPENNAMES_FILTER"
  echo "--   spd: $SPD_FILTER"
  echo
  echo "CREATE EXTENSION IF NOT EXISTS postgis;"
  echo
  "${PG_DUMP[@]}" --schema-only --section=pre-data -n pcio
  echo
  emit_copy onspd "$ONSPD_FILTER"
  emit_copy opennames "$OPENNAMES_FILTER"
  emit_copy spd "$SPD_FILTER"
  "${PG_DUMP[@]}" --schema-only --section=post-data -n pcio
} | gzip -9 > "$OUT"

uncompressed_kb="$(gunzip -c "$OUT" | wc -c | awk '{printf "%.0f", $1/1024}')"
gz_kb="$(wc -c < "$OUT" | awk '{printf "%.0f", $1/1024}')"
printf "wrote %s (%s KB gzipped, %s KB uncompressed)\n" "$OUT" "$gz_kb" "$uncompressed_kb"
